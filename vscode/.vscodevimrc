; VSCode Setting
; 
; "vim.useSystemClipboard": true,
; "vim.leader": "<space>",
; "vim.vimrc.enable": true,
; "vim.surround": true,
; "vim.sneak": true,
; "vim.easymotion": true,
; "vim.foldfix": true,
; "vim.scroll": 5,


; ╭──────────────────────────────────────────────────────────────────╮
; │  Keymaps (another keymaps at keybindings.json)                   │
; ╰──────────────────────────────────────────────────────────────────╯
; Set Windows Keymaps
nmap <Leader>f actions.find
nmap <Leader>t workbench.action.terminal.toggleTerminal
nmap <Leader>wa workbench.action.toggleActivityBarVisibility
nmap <Leader>wb workbench.action.toggleSidebarVisibility
nmap <Leader>wt workbench.action.toggleMenuBar
nmap <Leader>wz workbench.action.toggleZenMode
nmap <Leader>wh workbench.action.togglePanel

; Set LSP Keymaps
nmap K editor.action.showHover
nmap <Leader>lr editor.action.rename
nmap <Leader>lf editor.action.formatDocument
nmap <Leader>la editor.action.quickFix
; gb adds another cursor on the next word it finds which is the same as the word under the cursor.
; gd jump to definition
; gh similar to mouse hover
nmap gu editor.action.goToReferences
nmap gU editor.action.goToReferences
nmap [d editor.action.marker.prev
nmap ]d editor.action.marker.next